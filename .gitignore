# macOS
.DS_Store

# Secrets
.env
.env.*
!.env.example
!.env.sample
!.env.template
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc

# Virtual environment
.venv/
.python-version

# Tool caches (from the ruff / ty / pytest gates — run locally via hooks and in CI)
.pytest_cache/
.ruff_cache/
.ty_cache/

# Claude Code — share hooks via .claude/settings.json; ignore personal overrides
.claude/settings.local.json
# Per-turn sentinel written by the PostToolUse hook, consumed by the Stop hook
.claude/.tests-needed

# Local test data: chest X-rays in samples/cxr/ (comparison / Locate-anatomy), a CT
# DICOM series in samples/ct/, and a whole-slide image in samples/wsi/. Keep the
# directory's README so the test assets stay self-describing.
samples/*
!samples/README.md

# README hero: docs/screenshot.webp is committed; the full-page capture produced while
# regenerating it (see CLAUDE.md "Screenshots") is a throwaway.
docs/screenshot-full.png

# Build / packaging artifacts (pyproject now declares license-files for distributables)
build/
dist/
*.egg-info/

# Generated by uv export; not used for dependency management
requirements.txt
